<header class="biomc-header">
    <div class="biomc-nav">

        <a class="biomc-logo" href="/">
            {% if store.logo %}
                <img src="{{ store.logo }}" alt="{{ store.name }}">
            {% else %}
                <span>{{ store.name }}</span>
            {% endif %}
        </a>

        <nav class="biomc-menu">
            <a href="/">Inicio</a>
            <a href="/category/packages">Tienda</a>
            <a href="/checkout/packages">Carrito</a>
            <a href="/contact">Soporte</a>
        </nav>

        <a class="biomc-cart" href="/checkout/packages">
            Carrito
        </a>

    </div>

    <section class="biomc-hero">

        <div class="biomc-hero-content">

            <span class="biomc-badge">
                TIENDA OFICIAL
            </span>

            <h1>
                Bienvenido a {{ store.name }}
            </h1>

            <p>
                Rangos, llaves, kits y beneficios exclusivos para mejorar tu experiencia.
            </p>

            <div class="biomc-hero-actions">

                <a href="/category/packages" class="biomc-btn-primary">
                    Ver paquetes
                </a>

                <a href="/checkout/packages" class="biomc-btn-secondary">
                    Ver carrito
                </a>

            </div>

        </div>

    </section>

</header>
