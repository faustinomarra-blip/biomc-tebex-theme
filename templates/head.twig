<!DOCTYPE html>
<html lang="{{ store.locale|replace({'_':'-'}) }}">
<head>

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>{{ store.name }}{% if page.title %} - {{ page.title }}{% endif %}</title>

{% if store.favicon %}
<link rel="shortcut icon" href="{{ store.favicon }}">
{% endif %}

{% include "constants.twig" %}

<script src="{{ asset('swiper-element-bundle.min.js') }}"></script>
<script defer src="https://js.tebex.io/v/1.js"></script>
<script defer src="{{ asset('main.js') }}"></script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<link href="{{ asset('shared.css') }}" rel="stylesheet">
<link href="{{ asset('generic.css') }}" rel="stylesheet">

<style>

:root{

--biomc-bg:#05070a;
--biomc-bg2:#0d1117;

--biomc-card:#131a24;

--biomc-border:#1f2937;

--biomc-cyan:#00e5ff;

--biomc-green:#37ff8b;

--biomc-text:#ffffff;

--biomc-muted:#b7c2d6;

}

body{

background:var(--biomc-bg)!important;

color:var(--biomc-text)!important;

font-family:'Inter',sans-serif!important;

}

a{

color:var(--biomc-cyan);

}

</style>

</head>
